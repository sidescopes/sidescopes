{
    "version": 6,
    "configurePresets": [
        {
            "name": "vs",
            "displayName": "Visual Studio",
            "description": "The same build tree plain `cmake -B build` produces on Windows",
            "generator": "Visual Studio 18 2026",
            "binaryDir": "${sourceDir}/build",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "vs-werror",
            "displayName": "Visual Studio (warnings as errors)",
            "inherits": "vs",
            "binaryDir": "${sourceDir}/build-werror",
            "cacheVariables": {
                "SIDESCOPES_WERROR": "ON"
            }
        },
        {
            "name": "ide",
            "displayName": "Visual Studio IDE (Ninja)",
            "description": "For Open Folder in the IDE, which drives Ninja best; the IDE supplies the MSVC environment",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build-ide",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "vs",
            "configuration": "Debug",
            "nativeToolOptions": ["-m"]
        },
        {
            "name": "release",
            "configurePreset": "vs",
            "configuration": "Release",
            "nativeToolOptions": ["-m"]
        },
        {
            "name": "werror",
            "configurePreset": "vs-werror",
            "configuration": "Release",
            "nativeToolOptions": ["-m"]
        },
        {
            "name": "ide-debug",
            "configurePreset": "ide",
            "configuration": "Debug"
        },
        {
            "name": "ide-release",
            "configurePreset": "ide",
            "configuration": "Release"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "vs",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "release",
            "configurePreset": "vs",
            "configuration": "Release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
